# Copie para .env e preencha. O .env NUNCA é versionado.
# Chaves de LLM vão pelo gateway LiteLLM, não espalhadas por serviço.
LITELLM_BASE_URL=
LITELLM_VIRTUAL_KEY=vk-analise-credito-agro

# Mapeamento model_tier -> modelo no gateway (o manifesto pode sobrescrever
# via campo model_tiers). Defaults do motor se vazio:
MODEL_TIER_FAST=claude-haiku-4-5
MODEL_TIER_POWERFUL=claude-sonnet-5

# Observabilidade (plugue via Orchestrator(on_event=...))
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Fontes de dado (exemplos — preencha conforme o squad)
DATABASE_URL=
SERASA_API_KEY=
SCR_API_KEY=
