{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://audax.local/schemas/squad-schema.json",
  "title": "SQUAD.md Manifest (padrão Eric)",
  "description": "Valida o frontmatter YAML de um SQUAD.md. Rode em CI: nenhum squad malformado entra. Adaptado do squad-schema do AIOX para o contexto regulado (audax/externo/pessoal).",
  "type": "object",
  "required": ["name", "version", "profile", "context", "topology", "human_in_the_loop", "audit_trail", "source_citation"],
  "additionalProperties": true,
  "properties": {
    "name":        { "type": "string", "pattern": "^[a-z0-9-]+$", "minLength": 2, "maxLength": 50, "description": "kebab-case, único" },
    "version":     { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "description": "semver" },
    "description": { "type": "string", "maxLength": 500 },
    "owner":       { "type": "string" },
    "profile":     { "type": "string", "enum": ["app-web", "agente-ia", "hibrido"] },
    "context":     { "type": "string", "enum": ["audax", "externo", "pessoal"], "description": "define o rigor regulatório" },
    "regulatory":  { "type": "array", "items": { "type": "string", "enum": ["BACEN", "CMN", "LGPD", "ISO-42001"] } },

    "topology":     { "type": "string", "enum": ["orchestrator-worker", "swarm"], "default": "orchestrator-worker" },
    "orchestrator": { "type": "string" },
    "depends_on":   { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9-]+$" } },

    "max_iterations":        { "type": "integer", "minimum": 1, "maximum": 50 },
    "max_execution_seconds": { "type": "integer", "minimum": 1 },
    "max_cost_per_run_usd":  { "type": ["number", "null"], "minimum": 0 },
    "stop_on_no_progress":   { "type": "boolean" },
    "qa_reflection_rounds_max": { "type": "integer", "minimum": 0, "maximum": 5 },
    "agent_retry_max":       { "type": "integer", "minimum": 0, "maximum": 5, "description": "retries de erro transiente (429/5xx/timeout) por dispatch" },
    "agent_retry_backoff_seconds": { "type": "number", "minimum": 0 },

    "human_in_the_loop": { "type": "boolean", "description": "deve ser true em context=audax" },
    "audit_trail":       { "type": ["boolean", "string"], "enum": [true, false, "immutable"], "description": "o motor sempre grava state.json + events.jsonl + result.json; este campo declara o requisito" },
    "source_citation":   { "type": "string", "enum": ["required", "optional"] },
    "output_blocked_if": { "type": "array", "items": { "type": "string" } },

    "rating_scale":  { "type": "array", "items": { "type": "string" }, "description": "enforced: rating fora da escala é bloqueado pelo output_guardrail" },
    "model_tiers":   { "type": "object", "properties": { "fast": { "type": "string" }, "powerful": { "type": "string" } }, "additionalProperties": { "type": "string" }, "description": "mapeia tier -> modelo no gateway; sobrescreve MODEL_TIER_* do ambiente" },
    "llm_gateway":   { "type": "string" },
    "virtual_key":   { "type": "string", "pattern": "^vk-" },
    "tracing":       { "type": "string" },
    "metrics_lib":   { "type": "string" }
  },
  "allOf": [
    {
      "if":   { "properties": { "context": { "const": "audax" } } },
      "then": {
        "properties": {
          "human_in_the_loop": { "const": true },
          "audit_trail":       { "const": "immutable" },
          "source_citation":   { "const": "required" }
        },
        "required": ["human_in_the_loop", "audit_trail", "source_citation"],
        "description": "Em context=audax, governança é obrigatória e não-negociável."
      }
    }
  ]
}
